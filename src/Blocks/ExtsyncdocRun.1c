			_data = ext_sync_obj;
			_data.袙褋褌邪胁懈褌褜("Title", 袨褕懈斜泻邪小褌褉褍泻褌褍褉邪.detail);
			_data.袙褋褌邪胁懈褌褜("StatusId", "袨褕懈斜泻邪");
			_data.袙褋褌邪胁懈褌褜("StatusMsg", 袨褕懈斜泻邪小褌褉褍泻褌褍褉邪.message);
			_data.袙褋褌邪胁懈褌褜("Data", 
