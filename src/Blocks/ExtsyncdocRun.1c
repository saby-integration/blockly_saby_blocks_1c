		connection_uuid,
		command.Data.data.袠屑褟小袘袠小,
		command.Data.data.袠写小袘袠小,
		1
		);
		_data = 袧芯胁褘泄 小褌褉褍泻褌褍褉邪("ClientId, ClientName",
		result.袠写袠小,
		result.袧邪蟹胁邪薪懈械
		);
		local_helper_mapping_obj_find_and_update(
		context.params,
		_filter,
		_data
		);
		//pass
