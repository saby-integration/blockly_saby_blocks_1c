Функция block_extsyncdoc_run_command_getobject(context, block_context, ext_sync_obj)
	obj = ?(ext_sync_obj.Получить("Context") = Неопределено, Новый Структура(), ext_sync_obj["Context"]);
	obj.Вставить("ИдИС", ext_sync_obj.Получить("ClientId"));
	Возврат block_extsyncdoc_run_add_command_calc_ini(context, block_context, "read", ext_sync_obj, obj);
КонецФункции

Функция block_extsyncdoc_run_command_update(context, block_context, ext_sync_obj)
	Попытка
	    obj = ext_sync_obj.Data.data;
	Исключение
		ИнфОбОшибке = ИнформацияОбОшибке();
		ВызватьИсключение(NewExtException(ИнфОбОшибке, "Объект не содержит необходимый параметр"));
	КонецПопытки;
	Возврат block_extsyncdoc_run_add_command_calc_ini(context, block_context, "update", ext_sync_obj, obj);
КонецФункции

