Функция ЗаполнитьЗначенияApi3Objects(ТипСБИС, ИмяСБИС, object, block_context)
	param = Новый Соответствие;
	param.Вставить("ТипСБИС", ТипСБИС);
	param.Вставить("ИмяСБИС", ИмяСБИС);
	param.Вставить("ТипИС", object["ТипИС"]);
	param.Вставить("ИмяИС", object["ИмяИС"]);
	param.Вставить("ИдИС", object["ИдИС"]);
	Для каждого Поле из block_context цикл
		Если лев(Поле.Ключ,1) <> "_" Тогда
			param.Вставить(Поле.Ключ, Поле.Значение);
		КонецЕсли;
	КонецЦикла;
	Возврат param;	
КонецФункции
