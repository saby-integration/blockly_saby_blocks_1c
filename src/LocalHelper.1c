//headers - 小芯芯褌胁械褌褋褌胁懈械
肖褍薪泻褑懈褟 local_helper_add_auth_header(context_params, headers)
	袩械褉械屑 session;
	袝褋谢懈 袧械 context_params.小胁芯泄褋褌胁芯("session", session) 孝芯谐写邪
		session = "";
	袣芯薪械褑袝褋谢懈;
	headers.袙褋褌邪胁懈褌褜("X-SBISSessionID", session);
	
袣芯薪械褑肖褍薪泻褑懈懈

肖褍薪泻褑懈褟 local_helper_read_document(context_params, document) 协泻褋锌芯褉褌
	袩芯锌褘褌泻邪
		袪械蟹褍谢褜褌邪褌	=	local_helper_api(context_params, "小袘袠小.袩褉芯褔懈褌邪褌褜袛芯泻褍屑械薪褌",
		袧芯胁褘泄 小褌褉褍泻褌褍褉邪("袛芯泻褍屑械薪褌", document));
	袠褋泻谢褞褔械薪懈械
		袠薪褎芯袨斜袨褕懈斜泻械 = 袠薪褎芯褉屑邪褑懈褟袨斜袨褕懈斜泻械();
		//TODO 锌褉芯胁械褉泻邪 薪邪 芯褌褋褍褌褋褌胁褍懈械 写芯泻褍屑械薪褌邪
		parentStruct = ExtExceptionAnalyse(袠薪褎芯袨斜袨褕懈斜泻械);
		袝褋谢懈 ( 袧邪泄褌懈(parentStruct.message, "袨褕懈斜泻邪 API") > 0) 懈 (袠褋褌懈薪邪) 孝芯谐写邪
			//袝褋谢懈 薪械 薪邪泄写械薪 写芯泻褍屑械薪褌 //NotFound
			袙褘蟹胁邪褌褜袠褋泻谢褞褔械薪懈械 NewExtException小褌褉芯泻邪(袠薪褎芯袨斜袨褕懈斜泻械,,,,,"NotFound");
		袣芯薪械褑袝褋谢懈;
		袙褘蟹胁邪褌褜袠褋泻谢褞褔械薪懈械 NewExtException小褌褉芯泻邪(袠薪褎芯袨斜袨褕懈斜泻械);
	袣芯薪械褑袩芯锌褘褌泻懈;
	袙芯蟹胁褉邪褌 袪械蟹褍谢褜褌邪褌;
袣芯薪械褑肖褍薪泻褑懈懈

