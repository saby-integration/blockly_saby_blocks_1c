		proxy.校褋褌邪薪芯胁懈褌褜(proxy_param.protocol, proxy_param.server, 效懈褋谢芯(proxy_param.port), proxy_param.user, proxy_param.password);
	袣芯薪械褑袝褋谢懈;
	
	袝褋谢懈 袧械 kwargs.小胁芯泄褋褌胁芯("headers", headers) 孝芯谐写邪
		headers = 袧芯胁褘泄 小芯芯褌胁械褌褋褌胁懈械;
	袣芯薪械褑袝褋谢懈;
	
	袩芯锌褘褌泻邪
		http_connection = 袧芯胁褘泄 HTTP小芯械写懈薪械薪懈械(袗写褉械褋.host, 袗写褉械褋.port,,,proxy,,ssl);
		http_request	= 袧芯胁褘泄 HTTP袟邪锌褉芯褋(袗写褉械褋.resource, headers);
		袝褋谢懈 request_type = "post" 孝芯谐写邪
			http_request.校褋褌邪薪芯胁懈褌褜孝械谢芯袠蟹小褌褉芯泻懈(kwargs.data, "UTF-8");
		袠薪邪褔械袝褋谢懈 request_type = "post_binary" 孝芯谐写邪
			http_request.校褋褌邪薪芯胁懈褌褜袠屑褟肖邪泄谢邪孝械谢邪(kwargs.data);	
		袣芯薪械褑袝褋谢懈;
	袠褋泻谢褞褔械薪懈械
		袠薪褎袨斜袨褕懈斜泻械 = 袠薪褎芯褉屑邪褑懈褟袨斜袨褕懈斜泻械();
		袙褘蟹胁邪褌褜袠褋泻谢褞褔械薪懈械 NewExtException小褌褉芯泻邪(袠薪褎袨斜袨褕懈斜泻械, "袨褕懈斜泻邪 褋芯蟹写邪薪懈褟 HTTP 蟹邪锌褉芯褋邪");
	袣芯薪械褑袩芯锌褘褌泻懈;
	
	袝褋谢懈 request_type = "post" 袠袥袠 request_type = "post_binary" 孝芯谐写邪
		袩芯锌褘褌泻邪
			http_response	= http_connection.袨褌锌褉邪胁懈褌褜袛谢褟袨斜褉邪斜芯褌泻懈(http_request, 袠屑褟肖邪泄谢邪袨褌胁械褌邪);
		袠褋泻谢褞褔械薪懈械
			袠薪褎袨斜袨褕懈斜泻械 = 袠薪褎芯褉屑邪褑懈褟袨斜袨褕懈斜泻械();
			袙褘蟹胁邪褌褜袠褋泻谢褞褔械薪懈械 NewExtException小褌褉芯泻邪(袠薪褎袨斜袨褕懈斜泻械, "袨褕懈斜泻邪 胁褘锌芯谢薪械薪懈褟 HTTP 蟹邪锌褉芯褋邪");
		袣芯薪械褑袩芯锌褘褌泻懈;
	袠薪邪褔械袝褋谢懈 request_type = "get" 孝芯谐写邪
		袩芯锌褘褌泻邪
			http_response	= http_connection.袩芯谢褍褔懈褌褜(http_request, 袠屑褟肖邪泄谢邪袨褌胁械褌邪);
		袠褋泻谢褞褔械薪懈械
			袠薪褎袨斜袨褕懈斜泻械 = 袠薪褎芯褉屑邪褑懈褟袨斜袨褕懈斜泻械();
			袙褘蟹胁邪褌褜袠褋泻谢褞褔械薪懈械 NewExtException小褌褉芯泻邪(袠薪褎袨斜袨褕懈斜泻械, "袨褕懈斜泻邪 胁褘锌芯谢薪械薪懈褟 HTTP 蟹邪锌褉芯褋邪");
		袣芯薪械褑袩芯锌褘褌泻懈;
	袠薪邪褔械
		袙褘蟹胁邪褌褜袠褋泻谢褞褔械薪懈械 NewExtException小褌褉芯泻邪(,"袧械懈蟹胁械褋褌薪褘泄 褌懈锌 HTTP 蟹邪锌褉芯褋邪", request_type);		
	袣芯薪械褑袝褋谢懈;
	
	袙芯蟹胁褉邪褌 local_helper_exec_response(response_type, http_response, 袠屑褟肖邪泄谢邪袨褌胁械褌邪);		
	
袣芯薪械褑肖褍薪泻褑懈懈
		
肖褍薪泻褑懈褟 local_helper_exec_response(response_type, http_response, 袠屑褟肖邪泄谢邪袨褌胁械褌邪)
	
	response = 袧芯胁褘泄 小褌褉褍泻褌褍褉邪("code, result", http_response.袣芯写小芯褋褌芯褟薪懈褟);
	
	content_type = http_response.Headers["Content-Type"];
	袩芯锌褘褌泻邪
		袝褋谢懈 response.code = 200 孝芯谐写邪
			袝褋谢懈 response_type = "json" 孝芯谐写邪
				response.result = local_helper_json_loads(http_response.袩芯谢褍褔懈褌褜孝械谢芯袣邪泻小褌褉芯泻褍());	
			袠薪邪褔械袝褋谢懈 response_type = "text" 孝芯谐写邪
				response.result = http_response.袩芯谢褍褔懈褌褜孝械谢芯袣邪泻小褌褉芯泻褍();
			袠薪邪褔械袝褋谢懈 response_type = "binary" 孝芯谐写邪	
				response.result = 袠屑褟肖邪泄谢邪袨褌胁械褌邪;
			袣芯薪械褑袝褋谢懈;
		袠薪邪褔械
			袝褋谢懈 content_type = "application/json" 孝芯谐写邪
				response.result = local_helper_json_loads(http_response.袩芯谢褍褔懈褌褜孝械谢芯袣邪泻小褌褉芯泻褍());	
			懈薪邪褔械
				response.result = http_response.袩芯谢褍褔懈褌褜孝械谢芯袣邪泻小褌褉芯泻褍();
			袣芯薪械褑袝褋谢懈;
		袣芯薪械褑袝褋谢懈;
		袙芯蟹胁褉邪褌 response;		
	袠褋泻谢褞褔械薪懈械
		袠薪褎袨斜袨褕懈斜泻械 = 袠薪褎芯褉屑邪褑懈褟袨斜袨褕懈斜泻械();
		袙褘蟹胁邪褌褜袠褋泻谢褞褔械薪懈械 NewExtException小褌褉芯泻邪(袠薪褎袨斜袨褕懈斜泻械, "袨褕懈斜泻邪 褉邪蟹斜芯褉邪 HTTP 芯褌胁械褌邪");
	袣芯薪械褑袩芯锌褘褌泻懈;
