肖褍薪泻褑懈褟 local_helper_read_version_info(api_url, product_name)
	袝褋谢懈 api_url = 袧械芯锌褉械写械谢械薪芯 孝芯谐写邪
		prefix = "https://";
	袠薪邪褔械
		prefix = 袥械胁(api_url, 袧邪泄褌懈(api_url, "."));
		prefix = 袥械胁(prefix, 小褌褉袛谢懈薪邪(prefix) - 7);
	袣芯薪械褑袝褋谢懈;
	
	link = prefix + "update0.sbis.ru/1C/" + product_name + ".json";
	response = local_helper_exec_request("get", link, "json");
	袝褋谢懈 response.code = 200 孝芯谐写邪
		袙芯蟹胁褉邪褌 response.result
	袣芯薪械褑袝褋谢懈;
	袙褘蟹胁邪褌褜袠褋泻谢褞褔械薪懈械 NewExtException小褌褉芯泻邪(,"袨褕懈斜泻邪 蟹邪锌褉芯褋邪", response.code,,response.result);
袣芯薪械褑肖褍薪泻褑懈懈

袩褉芯褑械写褍褉邪 local_helper_pause(小械泻褍薪写褘)
	袝褋谢懈 小械泻褍薪写褘<> 0 孝芯谐写邪

        袧邪褋褌褉芯泄泻懈Proxy = 袧芯胁褘泄 袠薪褌械褉薪械褌袩褉芯泻褋懈(袥芯卸褜);
        袧邪褋褌褉芯泄泻懈Proxy.袧械袠褋锌芯谢褜蟹芯胁邪褌褜袩褉芯泻褋懈袛谢褟袥芯泻邪谢褜薪褘褏袗写褉械褋芯胁 = 袠褋褌懈薪邪;
        袧邪褋褌褉芯泄泻懈Proxy.袧械袠褋锌芯谢褜蟹芯胁邪褌褜袩褉芯泻褋懈袛谢褟袗写褉械褋芯胁.袛芯斜邪胁懈褌褜("127.0.0.0");

        袩芯锌褘褌泻邪
            小芯械写懈薪械薪懈械HTTP = 袧芯胁褘泄 HTTP小芯械写懈薪械薪懈械("127.0.0.0",,,,袧邪褋褌褉芯泄泻懈Proxy,小械泻褍薪写褘);
            小芯械写懈薪械薪懈械HTTP.袩芯谢褍褔懈褌褜(袧芯胁褘泄 HTTP袟邪锌褉芯褋());
        袠褋泻谢褞褔械薪懈械
            袙芯蟹胁褉邪褌;
        袣芯薪械褑袩芯锌褘褌泻懈;

    袣芯薪械褑袝褋谢懈;
	
袣芯薪械褑袩褉芯褑械写褍褉褘	

